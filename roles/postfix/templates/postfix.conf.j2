# Managed by Ansible for postfix
# Hide SMTP banner version information
smtpd_banner = $myhostname ESMTP
# Disable VRFY command to prevent user enumeration
disable_vrfy_command = yes
# Security and hardening settings
smtpd_helo_restrictions = permit_mynetworks, warn_if_reject reject_non_fqdn_helo, reject_invalid_helo_hostname, permit
smtpd_relay_restrictions = permit_mynetworks, permit_sasl_authenticated, defer_unauth_clients
smtpd_recipient_restrictions = permit_mynetworks, permit_sasl_authenticated, reject_unauth_destination
smtpd_client_restrictions = permit_mynetworks, reject_rbl_client zen.spamhaus.net

